# PostgreSQL Configuration
POSTGRES_USER=hekka
POSTGRES_PASSWORD=hekka_dev_password
POSTGRES_DB=hekka_market

# Database URLs (development)
DATABASE_URL=postgresql+asyncpg://hekka:hekka_dev_password@localhost:5432/hekka_market
DATABASE_URL_POOLED=postgresql+asyncpg://hekka:hekka_dev_password@localhost:6432/hekka_market

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Clerk Authentication
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
CLERK_JWKS_URL=https://api.clerk.dev/v1/jwks

# Lemon Squeezy Payments
LEMON_SQUEEZY_API_KEY=your_api_key
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret
LEMON_SQUEEZY_STORE_ID=your_store_id

# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# Frontend (for Vite)
VITE_SUPABASE_URL=http://localhost:5432
VITE_SUPABASE_ANON_KEY=not_used_anymore
VITE_API_URL=http://localhost:8000
